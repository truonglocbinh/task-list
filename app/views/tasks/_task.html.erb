<tr class="<%= task.completed_at.present? ? 'table-secondary' : task_row_class(task) %>" id="<%= dom_id(task) %>">
  <td class="text-center">
    <%= button_to toggle_complete_task_path(task), method: :patch, class: "btn btn-sm p-0 border-0" do %>
      <i class="<%= task.completed_at.present? ? 'bi bi-check-circle-fill text-success fs-5' : 'bi bi-circle fs-5' %>"></i>
    <% end %>
  </td>
  <td>
    <div class="<%= 'text-decoration-line-through text-muted' if task.completed_at.present? %>">
      <strong><%= task.title %></strong>
      <% if task.overdue? %>
        <span class="badge bg-danger ms-1"><i class="bi bi-exclamation-triangle"></i> OVERDUE</span>
      <% elsif task.due_today? && !task.completed_at.present? %>
        <span class="badge bg-info ms-1"><i class="bi bi-calendar-check"></i> Due Today</span>
      <% end %>
      <% if task.attachments.any? %>
        <span class="badge bg-secondary ms-1" title="<%= task.attachments.count %> attachment(s)">
          <i class="bi bi-paperclip"></i> <%= task.attachments.count %>
        </span>
      <% end %>
      <% if task.description.present? %>
        <br>
        <small class="text-muted"><%= truncate(task.description, length: 80) %></small>
      <% end %>
    </div>
  </td>
  <td>
    <% if task.due_at.present? %>
      <small class="<%= 'text-danger fw-bold' if task.overdue? %>">
        <i class="bi bi-calendar"></i>
        <%= task.due_at.strftime("%b %d, %Y") %>
        <br>
        <span class="<%= task.overdue? ? 'text-danger' : 'text-muted' %>"><%= task.due_at.strftime("%I:%M %p") %></span>
      </small>
    <% else %>
      <span class="text-muted">-</span>
    <% end %>
  </td>
  <td>
    <%= task_status_badge(task) %>
    <% if task.completed_at.present? %>
      <br>
      <small class="text-muted"><%= task.completed_at.strftime("%b %d, %I:%M %p") %></small>
    <% end %>
  </td>
  <td class="text-end">
    <div class="btn-group" role="group">
      <%= link_to task_path(task), class: "btn btn-sm btn-info", title: "View" do %>
        <i class="bi bi-eye"></i>
      <% end %>
      <%= link_to edit_task_path(task), class: "btn btn-sm btn-secondary", title: "Edit" do %>
        <i class="bi bi-pencil"></i>
      <% end %>
      <%= link_to task_path(task), 
          data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this task? This action cannot be undone." }, 
          class: "btn btn-sm btn-danger",
          title: "Delete" do %>
        <i class="bi bi-trash"></i>
      <% end %>
    </div>
  </td>
</tr>
