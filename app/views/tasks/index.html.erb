<div class="container mt-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1>My Tasks</h1>
    <%= link_to "New Task", new_task_path, class: "btn btn-primary" %>
  </div>

  <!-- Search Board -->
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <%= form_with url: tasks_path, method: :get, class: "row g-3", id: "search-form" do |f| %>
        <!-- Text Search -->
        <div class="col-12 col-lg-4">
          <label class="form-label">
            <i class="bi bi-search"></i> Search Tasks
          </label>
          <%= text_field_tag :search, params[:search], 
              class: "form-control", 
              placeholder: "Search by title or description..." %>
        </div>

        <!-- Status Filter -->
        <div class="col-6 col-md-3 col-lg-2">
          <label class="form-label">
            <i class="bi bi-list-check"></i> Status
          </label>
          <%= select_tag :status, 
              options_for_select(
                [
                  ["All Statuses", ""],
                  ["Pending", "pending"],
                  ["Completed", "completed"],
                  ["Overdue", "overdue"]
                ], 
                params[:status]
              ),
              class: "form-select" %>
        </div>

        <!-- Due Date Range Filter -->
        <div class="col-6 col-md-3 col-lg-2">
          <label class="form-label">
            <i class="bi bi-calendar"></i> From Date
          </label>
          <%= date_field_tag :due_date_from, params[:due_date_from], 
              class: "form-control",
              placeholder: "Start date" %>
        </div>

        <div class="col-6 col-md-3 col-lg-2">
          <label class="form-label">
            <i class="bi bi-calendar-range"></i> To Date
          </label>
          <%= date_field_tag :due_date_to, params[:due_date_to], 
              class: "form-control",
              placeholder: "End date" %>
        </div>

        <!-- Action Buttons -->
        <div class="col-6 col-md-3 col-lg-2 d-flex align-items-end gap-2">
          <%= button_tag type: "submit", class: "btn btn-primary flex-grow-1" do %>
            <i class="bi bi-funnel"></i> Filter
          <% end %>
          <%= link_to tasks_path, class: "btn btn-outline-secondary", title: "Clear filters" do %>
            <i class="bi bi-x-circle"></i>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Quick Filter Buttons -->
  <div class="mb-3 d-flex gap-2 align-items-center flex-wrap">
    <%= link_to "All Tasks", tasks_path, class: "btn btn-sm btn-#{params.except(:controller, :action).blank? ? 'primary' : 'outline-primary'}" %>
    <%= link_to "Due Today", tasks_path(filter: 'today'), class: "btn btn-sm btn-#{params[:filter] == 'today' ? 'primary' : 'outline-primary'}" %>
    
    <% if @overdue_count > 0 %>
      <span class="badge bg-danger ms-2">
        <i class="bi bi-exclamation-triangle"></i> <%= @overdue_count %> Overdue
      </span>
    <% end %>
    
    <% if params[:search].present? || params[:status].present? || params[:due_date].present? || params[:due_date_from].present? || params[:due_date_to].present? %>
      <span class="badge bg-info ms-2">
        <i class="bi bi-filter-circle"></i> Filters Active
      </span>
    <% end %>
  </div>

  <% if @tasks.any? %>
    <!-- Desktop Table View -->
    <div class="card shadow-sm d-none d-md-block">
      <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
          <thead class="table-light">
            <tr>
              <th class="text-center" style="width: 50px;"><i class="bi bi-check-circle"></i></th>
              <th>Task</th>
              <th style="width: 150px;">Due Date</th>
              <th style="width: 150px;">Status</th>
              <th class="text-end" style="width: 150px;">Actions</th>
            </tr>
          </thead>
          <tbody>
            <%= render @tasks %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Mobile Card View -->
    <div class="d-md-none">
      <%= render partial: 'task_mobile', collection: @tasks, as: :task %>
    </div>

    <!-- Pagination -->
    <div class="d-flex justify-content-between align-items-center mt-3 flex-wrap gap-2">
      <div class="text-muted">
        Showing <%= @tasks.offset_value + 1 %>-<%= [@tasks.offset_value + @tasks.length, @tasks.total_count].min %> 
        of <%= @tasks.total_count %> tasks
      </div>
      <div data-turbo-prefetch="false">
        <%= paginate @tasks, 
            params: params.permit(:search, :status, :due_date_from, :due_date_to, :filter).to_h %>
      </div>
    </div>
  <% else %>
    <div class="alert alert-info">
      <p class="mb-0">
        <% if params[:search].present? || params[:status].present? || params[:due_date].present? || params[:due_date_from].present? || params[:due_date_to].present? %>
          No tasks found matching your search criteria. <%= link_to "Clear filters", tasks_path, class: "alert-link" %>.
        <% elsif params[:filter] == 'today' %>
          No tasks due today. <%= link_to "View all tasks", tasks_path, class: "alert-link" %>.
        <% else %>
          No tasks yet. <%= link_to "Create your first task", new_task_path, class: "alert-link" %>!
        <% end %>
      </p>
    </div>
  <% end %>
</div>
