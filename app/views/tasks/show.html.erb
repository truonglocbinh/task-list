<div class="container mt-4">
  <div class="row justify-content-center">
    <div class="col-md-8">
      <div class="card">
        <div class="card-header d-flex justify-content-between align-items-center">
          <h2 class="mb-0">Task Details</h2>
          <%= link_to "Back to Tasks", tasks_path, class: "btn btn-sm btn-secondary" %>
        </div>
        <div class="card-body">
          <div class="mb-4">
            <h3 class="<%= 'text-decoration-line-through text-muted' if @task.completed_at.present? %>">
              <%= @task.title %>
            </h3>
            
            <% if @task.completed_at.present? %>
              <span class="badge bg-success">Completed</span>
            <% else %>
              <span class="badge bg-warning">Pending</span>
            <% end %>
          </div>

          <% if @task.description.present? %>
            <div class="mb-3">
              <h5>Description:</h5>
              <p class="<%= 'text-muted' if @task.completed_at.present? %>">
                <%= simple_format(@task.description) %>
              </p>
            </div>
          <% end %>

          <div class="mb-3">
            <p>
              <strong>Created:</strong> <%= @task.created_at.strftime("%B %d, %Y at %I:%M %p") %>
            </p>
            
            <% if @task.due_at.present? %>
              <p><strong>Due:</strong> <%= @task.due_at.strftime("%B %d, %Y at %I:%M %p") %></p>
            <% end %>
            
            <% if @task.completed_at.present? %>
              <p class="text-success">
                <strong>Completed:</strong> <%= @task.completed_at.strftime("%B %d, %Y at %I:%M %p") %>
              </p>
            <% end %>
          </div>

          <% if @task.attachments.any? %>
            <div class="mb-3">
              <h5><i class="bi bi-paperclip"></i> Attachments (<%= @task.attachments.count %>)</h5>
              <div class="list-group">
                <% @task.attachments.each do |attachment| %>
                  <div class="list-group-item d-flex flex-column flex-sm-row justify-content-between align-items-start align-items-sm-center gap-2">
                    <div class="d-flex align-items-center gap-2 flex-grow-1 overflow-hidden" style="min-width: 0; max-width: 100%;">
                      <i class="bi bi-paperclip text-primary flex-shrink-0"></i>
                      <div class="overflow-hidden file-container">
                        <span class="fw-semibold d-block text-truncate" style="max-width: 93%;" title="<%= attachment.filename %>">
                          <%= attachment.filename %>
                        </span>
                        <small class="text-muted"><%= number_to_human_size(attachment.byte_size) %></small>
                      </div>
                    </div>
                    <%= link_to "Download", rails_blob_path(attachment, disposition: "attachment"), 
                        class: "btn btn-sm btn-outline-primary flex-shrink-0" %>
                  </div>
                <% end %>
              </div>
            </div>
          <% end %>

          <div class="d-flex gap-2 mt-4">
            <%= button_to @task.completed_at.present? ? "Mark as Incomplete" : "Mark as Complete", 
                toggle_complete_task_path(@task), 
                method: :patch, 
                class: "btn btn-#{@task.completed_at.present? ? 'warning' : 'success'}" %>
            <%= link_to "Edit", edit_task_path(@task), class: "btn btn-secondary" %>
            <%= link_to "Delete", task_path(@task), 
                data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this task? This action cannot be undone." }, 
                class: "btn btn-danger" %>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
