<div class="card mb-3 shadow-sm <%= 'border-danger' if task.overdue? && !task.completed_at.present? %>" id="<%= dom_id(task) %>_mobile">
  <div class="card-body">
    <!-- Header: Checkbox + Title -->
    <div class="d-flex align-items-start gap-2 mb-2">
      <%= button_to toggle_complete_task_path(task), method: :patch, class: "btn btn-sm p-0 border-0 flex-shrink-0" do %>
        <i class="<%= task.completed_at.present? ? 'bi bi-check-circle-fill text-success fs-4' : 'bi bi-circle fs-4' %>"></i>
      <% end %>
      <div class="flex-grow-1">
        <h6 class="mb-1 <%= 'text-decoration-line-through text-muted' if task.completed_at.present? %>">
          <%= task.title %>
        </h6>
        <!-- Badges -->
        <div class="mb-2">
          <% if task.overdue? %>
            <span class="badge bg-danger"><i class="bi bi-exclamation-triangle"></i> OVERDUE</span>
          <% elsif task.due_today? && !task.completed_at.present? %>
            <span class="badge bg-info"><i class="bi bi-calendar-check"></i> Due Today</span>
          <% end %>
          <% if task.attachments.any? %>
            <span class="badge bg-secondary" title="<%= task.attachments.count %> attachment(s)">
              <i class="bi bi-paperclip"></i> <%= task.attachments.count %>
            </span>
          <% end %>
          <%= task_status_badge(task) %>
        </div>
      </div>
    </div>

    <!-- Description -->
    <% if task.description.present? %>
      <p class="text-muted small mb-2 <%= 'text-decoration-line-through' if task.completed_at.present? %>">
        <%= truncate(task.description, length: 120) %>
      </p>
    <% end %>

    <!-- Due Date -->
    <% if task.due_at.present? %>
      <div class="mb-2">
        <small class="<%= 'text-danger fw-bold' if task.overdue? %>">
          <i class="bi bi-calendar"></i> 
          <%= task.due_at.strftime("%b %d, %Y at %I:%M %p") %>
        </small>
      </div>
    <% end %>

    <!-- Completed Date -->
    <% if task.completed_at.present? %>
      <div class="mb-2">
        <small class="text-success">
          <i class="bi bi-check-circle"></i> 
          Completed: <%= task.completed_at.strftime("%b %d, %Y at %I:%M %p") %>
        </small>
      </div>
    <% end %>

    <!-- Actions -->
    <div class="d-flex gap-2 mt-3">
      <%= link_to task_path(task), class: "btn btn-sm btn-info flex-fill" do %>
        <i class="bi bi-eye"></i> View
      <% end %>
      <%= link_to edit_task_path(task), class: "btn btn-sm btn-secondary flex-fill" do %>
        <i class="bi bi-pencil"></i> Edit
      <% end %>
      <%= link_to task_path(task), 
          data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this task? This action cannot be undone." }, 
          class: "btn btn-sm btn-danger flex-fill" do %>
        <i class="bi bi-trash"></i> Delete
      <% end %>
    </div>
  </div>
</div>
